# ============================================================
# Knowledge Search - Environment Configuration
# ============================================================
# Copy this to .env and fill in your API keys:
#   cp .env.example .env
# ============================================================

# Embedding API (Alibaba Cloud Bailian)
# Get your key at: https://bailian.console.aliyun.com/
EMBEDDING_API_KEY="sk-your-bailian-api-key"
EMBEDDING_ENDPOINT="https://dashscope.aliyuncs.com/compatible-mode/v1/embeddings"
EMBEDDING_MODEL="text-embedding-v4"

# LLM API (Volcengine Ark / compatible)
# Get your key at: https://console.volcengine.com/ark/
LLM_API_KEY="your-ark-api-key"
LLM_ENDPOINT="https://ark.cn-beijing.volces.com/api/coding/v3/chat/completions"
LLM_MODEL="glm-5.2"
